{
  "info": {
    "name": "Blood Platform API",
    "_postman_id": "blood-platform-collection",
    "description": "Blood Bank Management Platform — modulith running on port 8080.\n\nAll responses follow:\n{\n  \"success\": true|false,\n  \"message\": \"...\",\n  \"data\": { ... },\n  \"errors\": { ... },\n  \"timestamp\": \"...\"\n}\n\nDefault seed admin: admin@blood.com / Admin1!\nRun 'Login (Admin)' first — token auto-saves to {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "description": "Modulith base URL" },
    { "key": "token", "value": "", "description": "JWT Bearer token — auto-set by any Login request." },
    { "key": "donorId", "value": "1", "description": "Donor ID — auto-set by Register Donor." },
    { "key": "inventoryId", "value": "1", "description": "Inventory ID — auto-set by Add Stock." }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register — DONOR",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@blood.com\",\n  \"password\": \"Password1!\",\n  \"role\": \"DONOR\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "description": "Register a new DONOR. New users start with PENDING_APPROVAL — an admin must approve before login."
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.success && json.data && json.data.token) {", "  pm.collectionVariables.set('token', json.data.token);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@blood.com\",\n  \"password\": \"Admin1!\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Login as seed admin. Token auto-saved to {{token}}."
          }
        },
        {
          "name": "Login (User)",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.success && json.data && json.data.token) {", "  pm.collectionVariables.set('token', json.data.token);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@blood.com\",\n  \"password\": \"Password1!\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "description": "Login as a non-admin user. Account must be ACTIVE (approved by admin)."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/auth/me", "host": ["{{baseUrl}}"], "path": ["api", "auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Admin — User Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users"] }
          }
        },
        {
          "name": "Get Pending Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/pending", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "pending"] }
          }
        },
        {
          "name": "Approve User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/25/approve", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "25", "approve"] }
          }
        },
        {
          "name": "Deactivate User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/25/deactivate", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "25", "deactivate"] }
          }
        },
        {
          "name": "Change User Role",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/users/25/role?newRole=DONOR", "host": ["{{baseUrl}}"], "path": ["api", "admin", "users", "25", "role"], "query": [{ "key": "newRole", "value": "DONOR" }] }
          }
        }
      ]
    },
    {
      "name": "Hospitals",
      "item": [
        {
          "name": "Register Hospital",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Lagos General Hospital\",\n  \"address\": \"1 Marina Road\",\n  \"state\": \"Lagos\",\n  \"city\": \"Lagos Island\",\n  \"contact\": \"08012345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/hospitals", "host": ["{{baseUrl}}"], "path": ["api", "hospitals"] },
            "description": "ADMIN only. Duplicate name+city rejected with 409."
          }
        },
        {
          "name": "Get All Hospitals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/hospitals", "host": ["{{baseUrl}}"], "path": ["api", "hospitals"] }
          }
        },
        {
          "name": "Get Hospital by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/hospitals/1", "host": ["{{baseUrl}}"], "path": ["api", "hospitals", "1"] }
          }
        },
        {
          "name": "Deactivate Hospital",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/hospitals/1/deactivate", "host": ["{{baseUrl}}"], "path": ["api", "hospitals", "1", "deactivate"] }
          }
        }
      ]
    },
    {
      "name": "Donors",
      "item": [
        {
          "name": "Register Donor",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.success && json.data && json.data.id) {", "  pm.collectionVariables.set('donorId', json.data.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"John Doe\",\n  \"bloodGroup\": \"O+\",\n  \"phone\": \"08012345678\"\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/donors", "host": ["{{baseUrl}}"], "path": ["api", "donors"] },
            "description": "Register donor profile for the logged-in user. donorId auto-saved to {{donorId}}.\nValid bloodGroup: A+, A-, B+, B-, AB+, AB-, O+, O-"
          }
        },
        {
          "name": "Get My Donor Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/donors/me", "host": ["{{baseUrl}}"], "path": ["api", "donors", "me"] }
          }
        },
        {
          "name": "List All Donors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/donors", "host": ["{{baseUrl}}"], "path": ["api", "donors"] }
          }
        },
        {
          "name": "Record Donation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"donationDate\": \"2026-06-16\",\n  \"hospitalName\": \"Lagos General Hospital\",\n  \"units\": 1\n}", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{baseUrl}}/api/donors/{{donorId}}/donations", "host": ["{{baseUrl}}"], "path": ["api", "donors", "{{donorId}}", "donations"] },
            "description": "IDOR protected — only the donor can record their own donation. Updates eligibility to NOT_ELIGIBLE for 3 months."
          }
        },
        {
          "name": "Get Donation History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/donors/{{donorId}}/donations?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "donors", "{{donorId}}", "donations"], "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }] },
            "description": "Paginated donation history, newest first. IDOR protected."
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "description": "InventoryController — /api/inventory\n\nWorkflow:\n1. Login as OFFICER/CLINICIAN/ADMIN (user must be linked to a hospital via hospitalId in JWT)\n2. Add Stock — inventoryId auto-saved to {{inventoryId}}\n3. Get Inventory — lists non-expired stock for your hospital\n4. Update Stock (correction) — PUT /{id}\n5. Get Audit Log — GET /{id}/audit",
      "item": [
        {
          "name": "Add Stock",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.success && json.data && json.data.id) {", "  pm.collectionVariables.set('inventoryId', json.data.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O+\",\n  \"units\": 10,\n  \"expiryDate\": \"2026-07-28\",\n  \"confirmShelfLife\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/inventory", "host": ["{{baseUrl}}"], "path": ["api", "inventory"] },
            "description": "Add blood stock for the authenticated user's hospital (scoped via JWT hospitalId).\n\nValid bloodGroup: A+, A-, B+, B-, AB+, AB-, O+, O-\n\nErrors:\n- 400: expiryDate is today or in the past\n- 422: shelf life > 42 days and confirmShelfLife=false (resubmit with confirmShelfLife=true)\n- 400: units <= 0\n\nSets inventoryId → {{inventoryId}}"
          }
        },
        {
          "name": "Add Stock (long shelf life — confirmed)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"A-\",\n  \"units\": 5,\n  \"expiryDate\": \"2026-12-31\",\n  \"confirmShelfLife\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/inventory", "host": ["{{baseUrl}}"], "path": ["api", "inventory"] },
            "description": "Resubmit with confirmShelfLife=true when expiry is more than 42 days away (e.g. frozen plasma)."
          }
        },
        {
          "name": "Get Hospital Inventory",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/inventory", "host": ["{{baseUrl}}"], "path": ["api", "inventory"] },
            "description": "Returns all non-expired inventory for the authenticated user's hospital. Expired records are filtered at query time."
          }
        },
        {
          "name": "Update Stock (correction)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"units\": 8,\n  \"reason\": \"Corrected after physical count — 2 units discarded (damaged bag)\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/inventory/{{inventoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "inventory", "{{inventoryId}}"] },
            "description": "Set absolute unit count with mandatory reason. Triggers audit log entry.\n\nErrors:\n- 400: units < 0\n- 400: units < reservedUnits\n- 404: inventory not found or belongs to another hospital\n- 409: concurrent update conflict (retry)"
          }
        },
        {
          "name": "Get Audit Log",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/inventory/{{inventoryId}}/audit", "host": ["{{baseUrl}}"], "path": ["api", "inventory", "{{inventoryId}}", "audit"] },
            "description": "Full audit trail for an inventory record — who changed what, when, and why. Ordered newest first."
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/notifications", "host": ["{{baseUrl}}"], "path": ["api", "notifications"] },
            "description": "List all notifications. Created automatically when a donor registers."
          }
        }
      ]
    },
    {
      "name": "Blood Search",
      "description": "BloodSearchController — GET /api/search/blood\n\nSearch for a blood group across all active hospitals.\nResults are sorted by proximity to the requesting user's hospital (same city first, then same state, then others), sub-sorted by available units descending.\nReserved units are excluded from the available count.\nDeactivated hospitals are excluded.\nWhen no results are found, compatible donor groups are suggested.",
      "item": [
        {
          "name": "Search Blood — O+",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/search/blood?bloodGroup=O%2B&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search", "blood"],
              "query": [
                { "key": "bloodGroup", "value": "O+" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            },
            "description": "Search all active hospitals for available O+ units.\n\nResponse data fields:\n- bloodGroup: the searched group\n- totalResults: total matching records\n- totalPages / page / size: pagination info\n- results[].availableUnits: unitsAvailable − unitsReserved\n- results[].lastUpdated: ISO timestamp — use to judge freshness\n- suggestions: non-null when results is empty — compatible donor groups to try next"
          }
        },
        {
          "name": "Search Blood — AB+ (universal recipient)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/search/blood?bloodGroup=AB%2B&page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search", "blood"],
              "query": [
                { "key": "bloodGroup", "value": "AB+" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Search Blood — invalid group (400)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/search/blood?bloodGroup=O%2B%2B",
              "host": ["{{baseUrl}}"],
              "path": ["api", "search", "blood"],
              "query": [{ "key": "bloodGroup", "value": "O++" }]
            },
            "description": "Expects 400 with valid values listed."
          }
        }
      ]
    }
  ]
}
