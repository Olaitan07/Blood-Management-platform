    {
      "name": "Inventory",
      "description": "InventoryController \u2014 /api/inventory\n\nWorkflow:\n1. Login as OFFICER/CLINICIAN/ADMIN (user must be linked to a hospital via hospitalId in JWT)\n2. Add Stock \u2014 inventoryId auto-saved to {{inventoryId}}\n3. Get Inventory \u2014 lists non-expired stock for your hospital\n4. Update Stock (correction) \u2014 PUT /{id}\n5. Get Audit Log \u2014 GET /{id}/audit",
      "item": [
        {
          "name": "Add Stock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.id) {",
                  "  pm.collectionVariables.set('inventoryId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"O+\",\n  \"units\": 10,\n  \"expiryDate\": \"2026-07-28\",\n  \"confirmShelfLife\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Add blood stock for the authenticated user's hospital (scoped via JWT hospitalId).\n\nValid bloodGroup: A+, A-, B+, B-, AB+, AB-, O+, O-\n\nErrors:\n- 400: expiryDate is today or in the past\n- 422: shelf life > 42 days and confirmShelfLife=false (resubmit with confirmShelfLife=true)\n- 400: units <= 0\n\nSets inventoryId \u2192 {{inventoryId}}"
          }
        },
        {
          "name": "Add Stock (long shelf life \u2014 confirmed)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bloodGroup\": \"A-\",\n  \"units\": 5,\n  \"expiryDate\": \"2026-12-31\",\n  \"confirmShelfLife\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Resubmit with confirmShelfLife=true when expiry is more than 42 days away (e.g. frozen plasma)."
          }
        },
        {
          "name": "Get Hospital Inventory",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory"
              ]
            },
            "description": "Returns all non-expired inventory for the authenticated user's hospital. Expired records are filtered at query time."
          }
        },
        {
          "name": "Update Stock (correction)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"units\": 8,\n  \"reason\": \"Corrected after physical count \u2014 2 units discarded (damaged bag)\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/inventory/{{inventoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{inventoryId}}"
              ]
            },
            "description": "Set absolute unit count with mandatory reason. Triggers audit log entry.\n\nErrors:\n- 400: units < 0\n- 400: units < reservedUnits\n- 404: inventory not found or belongs to another hospital\n- 409: concurrent update conflict (retry)"
          }
        },
        {
          "name": "Get Audit Log",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/inventory/{{inventoryId}}/audit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "inventory",
                "{{inventoryId}}",
                "audit"
              ]
            },
            "description": "Full audit trail for an inventory record \u2014 who changed what, when, and why. Ordered newest first."
          }
        }
      ]
    },
