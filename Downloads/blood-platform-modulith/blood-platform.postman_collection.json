{
  "info": {
    "name": "Blood Platform API",
    "_postman_id": "blood-platform-collection",
    "description": "Blood Bank Management Platform \u2014 modulith running on port 8080.\n\nAll responses follow:\n{\n  \"success\": true|false,\n  \"message\": \"...\",\n  \"data\": { ... },\n  \"errors\": { ... },\n  \"timestamp\": \"...\"\n}\n\nDefault seed admin: admin@blood.com / Admin1!\nRun 'Login (Admin)' first \u2014 token auto-saves to {{token}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "Modulith base URL"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT Bearer token \u2014 auto-set by any Login request."
    },
    {
      "key": "donorId",
      "value": "1",
      "description": "Donor ID \u2014 auto-set by Register Donor."
    },
    {
      "key": "inventoryId",
      "value": "1",
      "description": "Inventory ID \u2014 auto-set by Add Stock."
    },
    {
      "key": "transferId",
      "value": "1",
      "description": "Transfer request ID \u2014 auto-set by Create Transfer Request."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register \u2014 DONOR",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@blood.com\",\n  \"password\": \"Password1!\",\n  \"role\": \"DONOR\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new DONOR. New users start with PENDING_APPROVAL \u2014 an admin must approve before login."
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@blood.com\",\n  \"password\": \"Admin1!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login as seed admin. Token auto-saved to {{token}}."
          }
        },
        {
          "name": "Login (User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@blood.com\",\n  \"password\": \"Password1!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login as a non-admin user. Account must be ACTIVE (approved by admin)."
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
